# Default deployer key — used by bscTestnet, sepolia, mainnet networks
# in hardhat.config.js. Should match the EOA holding the deploy budget
# for whichever environment you're targeting; never reuse across nets.
PRIVATE_KEY=your_private_key_here

# Etherscan V2 unified API key. Single key covers Etherscan, BscScan,
# and Hoodi-Etherscan via the customChains entry in hardhat.config.js.
# Set BSCSCAN_API_KEY only when you specifically need BscScan and the
# Etherscan key is for some reason scoped narrower.
ETHERSCAN_API_KEY=your_etherscan_api_key_here
BSCSCAN_API_KEY=your_bscscan_api_key_here

# Optional per-network RPC overrides (defaults in hardhat.config.js point
# at publicnode endpoints). Override when you need a private RPC for
# rate limits or eth_call quirks.
# SEPOLIA_RPC_URL=https://...
# HOODI_RPC_URL=https://...

# ── HOODI testnet (chainId 560048) ───────────────────────────────────
#
# Deployer key for HOODI is intentionally a SEPARATE env var from
# PRIVATE_KEY: HOODI is the FYUSD x Concrete testnet (Concrete deployed
# FYUSD here because they don't support Sepolia), and the deployer wallet
# is generated fresh per env via `node scripts/gen-hoodi-deployer.js`.
# Keeping it separate caps the blast radius — losing this key never
# bleeds into Sepolia or mainnet ops.
#
# The actual key lives in .env.hoodi-deployer (gitignored). Source that
# file before running scripts/deploy-hoodi.js, e.g.:
#   source .env.hoodi-deployer
#   npx hardhat run scripts/deploy-hoodi.js --network hoodi
HOODI_DEPLOYER_PRIVATE_KEY=your_hoodi_testnet_deployer_key_here
