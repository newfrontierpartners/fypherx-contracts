# ────────────────────────────────────────────────────────────────────────────
# Dev environment Safe multisig + gas relayer keys (template)
# ────────────────────────────────────────────────────────────────────────────
#
# This is the COMMITTED template. The matching file with real keys lives
# next door at `.env.dev-multisig` (.env.* is already gitignored — see
# ../.gitignore line 4-6).
#
# Generated 2026-05-08 alongside ADR-012 (`docs/decisions/ADR-012-operator-
# multisig-and-gas-relayer.md`). These keys are intentionally hot dev keys
# — production rotates to hardware-wallet owners + KMS-bound gas relayer
# per ADR-012 §"Production rollout".
#
# Consumers:
#   - Phase 1 deploy scripts in this repo:
#       scripts/deploy-operator-safe.js
#       scripts/grant-admin-to-safe.js
#     read these to (a) seed the Safe deployment with the right owners,
#     (b) sign the role-grant tx as the deployer.
#
#   - Phase 2 backend k8s secret in `fypherx-backend-services` reads the
#     EXECUTOR_GAS_RELAYER_PRIVATE_KEY into the gateway pod env as
#     `BACKEND_GAS_RELAYER_PRIVATE_KEY`. The owner keys never go to the
#     backend — they stay on operator workstations / the Safe Wallet UI.
#
# To populate the local copy:
#   cp .env.dev-multisig.example .env.dev-multisig
#   # then fill the address + privkey pairs the team agreed on (or that
#   # were generated for ADR-012 — see #operations channel).
#
# DO NOT commit `.env.dev-multisig`. The .gitignore rule `.env.*` already
# covers it; double-check `git status` before pushing.

# ── Safe owners (3 EOAs, 2-of-3 threshold) ──────────────────────────────
# These keys belong to one operator each in production. For dev they are
# all kept here so a single developer can drive the full propose-sign-
# execute flow end-to-end without coordinating with two more humans.

OWNER_1_ADDRESS=0xREPLACE_ME
OWNER_1_PRIVATE_KEY=0xREPLACE_ME

OWNER_2_ADDRESS=0xREPLACE_ME
OWNER_2_PRIVATE_KEY=0xREPLACE_ME

OWNER_3_ADDRESS=0xREPLACE_ME
OWNER_3_PRIVATE_KEY=0xREPLACE_ME

# ── Gas relayer (hot key, backend pod) ──────────────────────────────────
# Submits Safe.execTransaction(...) calls and pays the gas. Holds NO
# admin role and NO operator-side assets — the blast radius of a leak is
# bounded to its own Sepolia ETH balance.

EXECUTOR_GAS_RELAYER_ADDRESS=0xREPLACE_ME
EXECUTOR_GAS_RELAYER_PRIVATE_KEY=0xREPLACE_ME

# ── Safe contract address (filled in Phase 1) ───────────────────────────
# Populated after the Safe is deployed via the Safe Wallet UI; this is
# the contract address that holds DEFAULT_ADMIN_ROLE on every Phase-1
# contract once `grant-admin-to-safe.js` has run.

OPERATOR_SAFE_ADDRESS=0xTBD_AFTER_PHASE_1_DEPLOY
